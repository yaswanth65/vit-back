{
  "name": "vituor-backend",
  "version": "1.0.0",
  "description": "VITUOR Scholarly Manuscript Management System",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "lint": "eslint \"src/**/*.js\" --max-warnings=0 --quiet",
    "lint:fix": "eslint \"src/**/*.js\" --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --passWithNoTests",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "build": "echo 'Preparing for production...' && npm install --omit=dev",
    "db:migrate": "sequelize-cli db:migrate",
    "db:migrate:undo:all": "sequelize-cli db:migrate:undo:all",
    "db:migrate:status": "sequelize-cli db:migrate:status",
    "db:seed": "sequelize-cli db:seed:all",
    "db:seed:undo": "sequelize-cli db:seed:undo:all",
    "db:seed:file": "sequelize-cli db:seed --seed"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.986.0",
    "@elastic/elasticsearch": "^8.0.0",
    "@sendgrid/mail": "^8.1.0",
    "@sentry/node": "^7.0.0",
    "axios": "^1.13.5",
    "bcrypt": "^5.1.1",
    "clamscan": "^2.1.2",
    "colors": "^1.4.0",
    "cors": "^2.8.6",
    "crypto": "^1.0.1",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.19.0",
    "handlebars": "^4.7.8",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.6.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "natural": "^6.10.1",
    "nodemailer": "^8.0.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "passport-orcid": "^0.0.2",
    "passport-saml": "^3.2.4",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.14.0",
    "pg": "^8.18.0",
    "pg-hstore": "^2.3.4",
    "qrcode": "^1.5.3",
    "rate-limit-redis": "^4.2.0",
    "redis": "^4.6.11",
    "sequelize": "^6.37.7",
    "sharp": "^0.33.0",
    "socket.io": "^4.7.2",
    "speakeasy": "^2.0.0",
    "stripe": "^14.5.0",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "eslint-plugin-import": "^2.29.1",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "sequelize-cli": "^6.6.5",
    "supertest": "^6.3.3"
  }
}
